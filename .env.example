APP_ENV=development
POSTGRES_DB=tolmach
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Локальный compose использует этот URL.
# Для внешней PostgreSQL укажите здесь production DSN:
# DATABASE_URL=postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://postgres:postgres@db:5432/tolmach

ANALYTICS_DATABASE_NAME=drivee_prod
JWT_SECRET=change-me-in-production
FRONTEND_ORIGIN=http://localhost:5173

# Локальная Ollama.
# Если backend запускается без Docker: http://localhost:11434
# Если backend запускается в Docker Desktop: http://host.docker.internal:11434
LLM_PROVIDER=ollama
LLM_MODEL=qwen3:4b
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Production-compatible OpenAI-style gateway.
# Base URL should point to the API root that exposes /chat/completions.
# Example: https://api.openai.com/v1
PRODUCTION_LLM_BASE_URL=
PRODUCTION_LLM_API_KEY=
PRODUCTION_LLM_MODEL=

# Optional embeddings provider for hybrid retrieval.
# Use `disabled` to keep retrieval purely lexical on pg_trgm.
EMBEDDING_PROVIDER=disabled
EMBEDDING_MODEL=
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_MAX_RETRIES=2

LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_MS=250
LLM_PROMPT_INTENT_VERSION=v1
LLM_PROMPT_CLARIFICATION_VERSION=v1
LLM_PROMPT_PLAN_VERSION=v1
LLM_PROMPT_SUMMARY_VERSION=v1

RETRIEVAL_ENABLE_VECTORS=true
RETRIEVAL_TOP_K_TERMS=8
RETRIEVAL_TOP_K_TEMPLATES=4
RETRIEVAL_TOP_K_EXAMPLES=4
RETRIEVAL_PLANNER_TOP_K=12
RETRIEVAL_LEXICAL_CANDIDATE_POOL=24
RETRIEVAL_VECTOR_CANDIDATE_POOL=16
RETRIEVAL_TERM_THRESHOLD=0.08
RETRIEVAL_TEMPLATE_THRESHOLD=0.06
RETRIEVAL_EXAMPLE_THRESHOLD=0.06

QUERY_TIMEOUT_MS=5000
SQL_LOCK_TIMEOUT_MS=1000
SQL_IDLE_IN_TRANSACTION_TIMEOUT_MS=10000
SQL_EXPLAIN_MAX_COST=200000
QUERY_CACHE_ENABLED=true
QUERY_CACHE_TTL_SECONDS=300
QUERY_CACHE_MAX_ROWS=500
QUERY_CACHE_NAMESPACE=v1
QUERY_OBSERVABILITY_LIMIT=200
BENCHMARK_DEFAULT_ITERATIONS=7
BENCHMARK_P95_TARGET_MS=1200

# Optional Phoenix/OpenTelemetry endpoints.
# Browser/host tools can use localhost; backend container must use phoenix.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
BACKEND_OTEL_EXPORTER_OTLP_ENDPOINT=http://phoenix:4317

VITE_API_URL=http://localhost:8000
