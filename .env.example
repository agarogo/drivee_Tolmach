APP_ENV=development

POSTGRES_DB=tolmach
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Local docker-compose keeps platform and analytics in the same PostgreSQL DSN.
# In production you can split them, but ANALYTICS_DATABASE_URL must already contain
# the governed fact/dim/mart tables used by the query executor.
PLATFORM_DATABASE_URL=postgresql://postgres:postgres@db:5432/tolmach
ANALYTICS_DATABASE_URL=postgresql://postgres:postgres@db:5432/tolmach

FRONTEND_ORIGINS=http://localhost:5173

SESSION_COOKIE_NAME=tolmach_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
CSRF_COOKIE_NAME=tolmach_csrf
CSRF_HEADER_NAME=X-CSRF-Token

LLM_PROVIDER=ollama
LLM_MODEL=qwen3:4b
OLLAMA_BASE_URL=http://ollama:11434

# OpenAI-compatible production gateway.
PRODUCTION_LLM_BASE_URL=
PRODUCTION_LLM_API_KEY=
PRODUCTION_LLM_MODEL=

EMBEDDING_PROVIDER=disabled
EMBEDDING_MODEL=
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_MAX_RETRIES=2

LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_MS=250
LLM_STRICT_MODE=false
LLM_RULE_FALLBACK_ENABLED=true
LLM_PROMPT_CLASSIFIER_VERSION=v1
LLM_PROMPT_INTENT_VERSION=v1
LLM_PROMPT_CLARIFICATION_VERSION=v1
LLM_PROMPT_PLAN_VERSION=v1
LLM_PROMPT_SUMMARY_VERSION=v1

RETRIEVAL_ENABLE_VECTORS=true
RETRIEVAL_TOP_K_TERMS=8
RETRIEVAL_TOP_K_TEMPLATES=4
RETRIEVAL_TOP_K_EXAMPLES=4
RETRIEVAL_PLANNER_TOP_K=12
RETRIEVAL_LEXICAL_CANDIDATE_POOL=24
RETRIEVAL_VECTOR_CANDIDATE_POOL=16
RETRIEVAL_TERM_THRESHOLD=0.08
RETRIEVAL_TEMPLATE_THRESHOLD=0.06
RETRIEVAL_EXAMPLE_THRESHOLD=0.06

QUERY_TIMEOUT_MS=5000
SQL_LOCK_TIMEOUT_MS=1000
SQL_IDLE_IN_TRANSACTION_TIMEOUT_MS=10000
SQL_EXPLAIN_MAX_COST=200000
QUERY_CACHE_ENABLED=true
QUERY_CACHE_TTL_SECONDS=300
QUERY_CACHE_MAX_ROWS=500
QUERY_CACHE_NAMESPACE=v1
QUERY_OBSERVABILITY_LIMIT=200
BENCHMARK_DEFAULT_ITERATIONS=7
BENCHMARK_P95_TARGET_MS=1200

SCHEDULER_ENABLED=true
SCHEDULER_POLL_INTERVAL_SECONDS=15
SCHEDULER_BATCH_SIZE=10
SCHEDULER_MAX_CONCURRENT_RUNS=2
SCHEDULER_DEFAULT_MAX_RETRIES=2
SCHEDULER_DEFAULT_RETRY_BACKOFF_SECONDS=300

REPORT_ARTIFACT_DIR=/tmp/tolmach-report-artifacts
REPORT_RESULT_SNAPSHOT_LIMIT=200
REPORT_EMAIL_ADAPTER=smtp
REPORT_EMAIL_FROM=reports@tolmach.local
REPORT_SMTP_HOST=
REPORT_SMTP_PORT=587
REPORT_SMTP_USERNAME=
REPORT_SMTP_PASSWORD=
REPORT_SMTP_USE_TLS=true
REPORT_SMTP_USE_SSL=false
REPORT_SLACK_ADAPTER=webhook
REPORT_SLACK_WEBHOOK_URL=
REPORT_DELIVERY_TIMEOUT_SECONDS=20

DEMO_BOOTSTRAP_ALLOW_NONLOCAL=false

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
BACKEND_OTEL_EXPORTER_OTLP_ENDPOINT=http://phoenix:4317

VITE_API_URL=http://localhost:8000
VITE_CSRF_COOKIE_NAME=tolmach_csrf
VITE_CSRF_HEADER_NAME=X-CSRF-Token
