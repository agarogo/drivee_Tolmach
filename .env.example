POSTGRES_DB=tolmach
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Локальный compose использует этот URL.
# Для внешней PostgreSQL укажите здесь production DSN:
# DATABASE_URL=postgresql://user:password@host:5432/database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/tolmach

ANALYTICS_DATABASE_NAME=drivee_prod
JWT_SECRET=change-me-in-production
FRONTEND_ORIGIN=http://localhost:5173

# Локальная Ollama.
# Если backend запускается без Docker: http://localhost:11434
# Если backend запускается в Docker Desktop: http://host.docker.internal:11434
LLM_PROVIDER=ollama
LLM_MODEL=qwen3:4b
OLLAMA_BASE_URL=http://host.docker.internal:11434
LLM_TEMPERATURE=0.1

# Optional Phoenix/OpenTelemetry endpoints.
# Browser/host tools can use localhost; backend container must use phoenix.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
BACKEND_OTEL_EXPORTER_OTLP_ENDPOINT=http://phoenix:4317

VITE_API_URL=http://localhost:8000
